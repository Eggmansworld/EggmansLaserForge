<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ldp.App.RenameDialog"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BgWindow}">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Name="PromptText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource FgMuted}" Text=""/>
        <TextBox Name="InputBox" FontSize="14" KeyDown="OnKeyDown"/>
        <TextBlock Name="ErrorText" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource PortDeath}" IsVisible="False"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Name="OkButton" Content="Rename" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
